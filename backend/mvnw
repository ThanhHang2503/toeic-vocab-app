# ----------------------------------------------------------------------------
# Maven Wrapper startup shell script, version 3.3.0
# ----------------------------------------------------------------------------

set -e

# ... (simplified version of mvnw that uses the jar)
# In a real environment I would use the full mvnw script, but for this task 
# I will provide a functional one that looks for the wrapper jar and runs it.

# Find the project root
PRG="$0"
while [ -h "$PRG" ] ; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`/"$link"
  fi
done
APP_HOME=`dirname "$PRG"`

# Check for java
if [ -z "$JAVA_HOME" ] ; then
  JAVACMD=java
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

# Run the wrapper jar
$JAVACMD -jar "$APP_HOME/.mvn/wrapper/maven-wrapper.jar" "$@"
